{
  "name": "@tractorbeam/eslint-config",
  "version": "0.3.0",
  "description": "Shared ESLint configuration for Tractorbeam projects",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslintconfig",
    "playwright",
    "prettier",
    "react",
    "tanstack",
    "tractorbeam",
    "tractorbeamai",
    "typescript"
  ],
  "homepage": "https://github.com/tractorbeamai/reusables/tree/main/packages/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/tractorbeamai/reusables/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tractorbeamai/reusables.git",
    "directory": "packages/eslint-config"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./base": {
      "types": "./dist/base.d.ts",
      "default": "./dist/base.js"
    },
    "./typescript": {
      "types": "./dist/typescript.d.ts",
      "default": "./dist/typescript.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./tanstack-router": {
      "types": "./dist/tanstack-router.d.ts",
      "default": "./dist/tanstack-router.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    },
    "./cloudflare-workers": {
      "types": "./dist/cloudflare-workers.d.ts",
      "default": "./dist/cloudflare-workers.js"
    },
    "./playwright": {
      "types": "./dist/playwright.d.ts",
      "default": "./dist/playwright.js"
    },
    "./prettier": {
      "types": "./dist/prettier.d.ts",
      "default": "./dist/prettier.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "default": "./dist/ui.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "default": "./dist/zod.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint:types": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@eslint/js": "10.0.1",
    "@tanstack/eslint-plugin-router": "1.141.0",
    "@typescript-eslint/utils": "8.50.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-depend": "1.4.0",
    "eslint-plugin-import-lite": "0.4.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-playwright": "2.4.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.26",
    "eslint-plugin-regexp": "2.10.0",
    "eslint-plugin-unicorn": "72.0.0",
    "eslint-plugin-zod": "4.8.0",
    "globals": "17.7.0",
    "typescript-eslint": "8.50.0"
  },
  "devDependencies": {
    "@tractorbeam/typescript-config": "workspace:*",
    "@types/eslint": "9.6.1",
    "@types/eslint-plugin-jsx-a11y": "6.10.1",
    "@types/node": "25.0.3",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "eslint": ">= 9",
    "typescript-eslint": ">= 8"
  }
}
