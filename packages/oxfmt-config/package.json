{
  "name": "@tractorbeam/oxfmt-config",
  "version": "0.1.0",
  "description": "Shared Oxfmt configuration for Tractorbeam projects",
  "keywords": [
    "config",
    "formatter",
    "oxfmt",
    "tractorbeam",
    "tractorbeamai"
  ],
  "homepage": "https://github.com/tractorbeamai/reusables/tree/main/packages/oxfmt-config#readme",
  "bugs": {
    "url": "https://github.com/tractorbeamai/reusables/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tractorbeamai/reusables.git",
    "directory": "packages/oxfmt-config"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint:types": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@tractorbeam/typescript-config": "workspace:*",
    "oxfmt": "0.59.0",
    "typescript": "5.9.3"
  }
}
