{
  "name": "@tractorbeam/vite-plugin-mcp-apps",
  "version": "0.1.0",
  "description": "Build filesystem-based MCP Apps as self-contained HTML files with Vite",
  "keywords": [
    "mcp",
    "mcp-apps",
    "model-context-protocol",
    "plugin",
    "tractorbeam",
    "vite"
  ],
  "homepage": "https://github.com/tractorbeamai/reusables/tree/main/packages/vite-plugin-mcp-apps#readme",
  "bugs": {
    "url": "https://github.com/tractorbeamai/reusables/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tractorbeamai/reusables.git",
    "directory": "packages/vite-plugin-mcp-apps"
  },
  "files": [
    "dist/**",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp pack",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint:types": "tsc --noEmit",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm run build && node --test test/*.test.js"
  },
  "dependencies": {
    "parse5": "8.0.1",
    "postcss": "8.5.19",
    "postcss-value-parser": "4.2.0",
    "tinyglobby": "0.2.17",
    "vite-plugin-singlefile": "2.3.3"
  },
  "devDependencies": {
    "@tractorbeam/typescript-config": "workspace:*",
    "@types/node": "24.13.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vite-plus": "0.2.4"
  },
  "peerDependencies": {
    "vite": "^8.0.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
